[Unit]
Description=Hyprneko — Wayland-native desktop pet
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/hyprneko
Restart=on-failure
RestartSec=2

# Hardening: hyprneko only needs read access to its config and write access
# to $XDG_RUNTIME_DIR/hyprneko (for the control socket). Tighten further with
# sandboxing options if your distro supports them.

[Install]
WantedBy=graphical-session.target
